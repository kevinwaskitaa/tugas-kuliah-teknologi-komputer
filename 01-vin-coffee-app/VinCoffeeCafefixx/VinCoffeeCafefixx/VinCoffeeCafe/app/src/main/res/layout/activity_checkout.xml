<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutralwhite"
    tools:context=".CheckoutActivity">

    <!-- 1. HEADER BLUE BACKGROUND -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/header_rounded_bottom"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_back_checkout"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/back"
        app:layout_constraintBottom_toBottomOf="@id/header_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/neutralwhite" />

    <TextView
        android:id="@+id/tv_title_checkout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:text="Checkout"
        android:textColor="@color/neutralwhite"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/header_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- CONTENT SCROLLVIEW -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 2. ALAMAT PENGIRIMAN SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alamat Pengiriman"
                android:textColor="@color/neutralblack"
                android:textSize="14sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip_normal"
                android:backgroundTint="#D9D9D9"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/ic_location_pin"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/lok_check"
                    app:tint="@color/primaryblue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ic_location_pin"
                    android:layout_toStartOf="@id/ic_arrow_right"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:text="Rumah Keysha - Jl. Teknologi No. 8\nKelurahan Bantar Asri"
                    android:textColor="@color/neutralblack"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp" />

                <ImageView
                    android:id="@+id/ic_arrow_right"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/right"
                    app:tint="@color/neutraldark_grey" />
            </RelativeLayout>

            <!-- 3. METODE PEMBAYARAN SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Metode Pembayaran"
                android:textColor="@color/neutralblack"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- PILIHAN DANA (SELECTED / AKTIF) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip_normal"
                android:backgroundTint="#D9D9D9"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/ic_card_dana"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/payment"
                    app:tint="@color/primaryblue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ic_card_dana"
                    android:layout_marginStart="16dp"
                    android:text="DANA"
                    android:textColor="@color/neutralblack"
                    android:textSize="14sp"
                    android:textStyle="normal" />

                <!-- Indikator Lingkaran Aktif (Biru) -->
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/ellipse_selected" />
            </RelativeLayout>

            <!-- PILIHAN OVO -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_normal"
                android:backgroundTint="#D9D9D9"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/ic_card_ovo"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/payment"
                    app:tint="@color/neutraldark_grey" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ic_card_ovo"
                    android:layout_marginStart="16dp"
                    android:text="OVO"
                    android:textColor="@color/neutralblack"
                    android:textSize="14sp" />

                <!-- Indikator Lingkaran Tidak Aktif (Abu-abu) -->
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/ellipse_unselected" />
            </RelativeLayout>

            <!-- PILIHAN GOPAY -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_normal"
                android:backgroundTint="#D9D9D9"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/ic_card_gopay"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/payment"
                    app:tint="@color/neutraldark_grey" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ic_card_gopay"
                    android:layout_marginStart="16dp"
                    android:text="Gopay"
                    android:textColor="@color/neutralblack"
                    android:textSize="14sp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/ellipse_unselected" />
            </RelativeLayout>

            <!-- 4. RINCIAN BIAYA SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="Subtotal Produk: Rp 108.000"
                android:textColor="@color/neutralblack"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Biaya Pengiriman: Rp 8.000"
                android:textColor="@color/neutralblack"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_total_bayar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Total Bayar: Rp. 116.000"
                android:textColor="@color/neutralblack"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- 5. ENKRIPSI AMAN FOOTER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/kunci"
                    app:tint="@color/neutraldark_grey" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Pembayaran Aman &amp; Terenkripsi"
                    android:textColor="@color/neutraldark_grey"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 6. TOMBOL BAYAR SEKARANG -->
            <Button
                android:id="@+id/btn_bayar_sekarang"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/primaryblue"
                android:text="Bayar Sekarang"
                android:textAllCaps="false"
                android:textColor="@color/neutralwhite"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>