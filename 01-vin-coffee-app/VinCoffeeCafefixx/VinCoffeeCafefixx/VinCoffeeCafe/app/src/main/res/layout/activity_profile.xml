<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ProfileActivity">

    <!-- Konten Scrollable Profil -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navbar"
        android:scrollbars="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header Biru Utama (.rectangle) -->
            <View
                android:id="@+id/header_background"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/header_rounded_bottom" />

            <!-- Tombol Back Panah Kiri (.mingcute-arrow-left) -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="60dp"
                android:layout_marginStart="24dp"
                android:src="@drawable/back"
                android:clickable="true"
                android:focusable="true" />

            <!-- Lingkaran Foto Profil (.ellipse) -->
            <View
                android:id="@+id/profile_circle"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="60dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/bg_profile" />

            <!-- Ikon User di dalam Lingkaran (.cuida-user-outline) -->
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignTop="@id/profile_circle"
                android:layout_alignBottom="@id/profile_circle"
                android:layout_alignStart="@id/profile_circle"
                android:layout_alignEnd="@id/profile_circle"
                android:layout_margin="16dp"
                android:src="@drawable/profile"
                app:tint="#FFFFFF" />

            <!-- Teks Nama Pengguna (.text-wrapper) -->
            <TextView
                android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/profile_circle"
                android:layout_marginTop="12dp"
                android:layout_centerHorizontal="true"
                android:text="Keysha"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Teks Email Pengguna (.text-wrapper-9) -->
            <TextView
                android:id="@+id/tv_profile_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_profile_name"
                android:layout_marginTop="4dp"
                android:layout_centerHorizontal="true"
                android:alpha="0.8"
                android:text="keysha123@gmail.com"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <!-- ================= DAFTAR MENU OPSI VERTIKAL ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/header_background"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="vertical">

                <!-- 1. Riwayat Pesanan -->
                <LinearLayout
                    android:id="@+id/menu_riwayat"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/history"
                        app:tint="#757575" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Riwayat Pesanan"
                        android:textColor="#757575"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 2. Metode Pembayaran -->
                <LinearLayout
                    android:id="@+id/menu_pembayaran"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/payment"
                        app:tint="#757575" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Metode Pembayaran"
                        android:textColor="#757575"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 3. Voucher Saya -->
                <LinearLayout
                    android:id="@+id/menu_voucher"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/promo"
                        app:tint="#757575" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Voucher Saya"
                        android:textColor="#757575"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 4. Pengaturan -->
                <LinearLayout
                    android:id="@+id/menu_pengaturan"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/pengaturan"
                        app:tint="#757575" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Pengaturan"
                        android:textColor="#757575"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 5. Pusat Bantuan -->
                <LinearLayout
                    android:id="@+id/menu_bantuan"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/bantuan"
                        app:tint="#757575" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Pusat Bantuan"
                        android:textColor="#757575"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 6. Info Aplikasi -->
                <LinearLayout
                    android:id="@+id/menu_info"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/info"
                        app:tint="#757575" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Info Aplikasi"
                        android:textColor="#757575"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 7. Keluar (Teks & Ikon Berwarna Merah Semantic) -->
                <LinearLayout
                    android:id="@+id/menu_keluar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/keluar"
                        app:tint="#D32F2F" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Keluar"
                        android:textColor="#D32F2F"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Teks Versi Aplikasi (.text-wrapper-10) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="24dp"
                    android:text="Vin Coffee App v1.0.4"
                    android:textColor="#757575"
                    android:textSize="14sp" />

            </LinearLayout>
        </RelativeLayout>
    </ScrollView>

    <!-- KAPSUL NAVBAR AKTIF (.navbar) -->
    <LinearLayout
        android:id="@+id/bottom_navbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#89CFF0"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/home"
            android:contentDescription="Home"
            app:tint="@color/primaryblue" />

        <ImageView
            android:id="@+id/nav_maps"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/location"
            android:contentDescription="Maps"
            app:tint="@color/primaryblue" />

        <ImageView
            android:id="@+id/nav_vouchers"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/promo"
            android:contentDescription="Vouchers"
            app:tint="@color/primaryblue" />

        <ImageView
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/profile"
            android:contentDescription="Profile"
            app:tint="@color/primaryblue" />
    </LinearLayout>

</RelativeLayout>