<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutralwhite"
    tools:context=".LokasiOutletActivity">

    <!-- 1. HEADER BLUE BESERTA SEARCH BAR DI DALAMNYA -->
    <RelativeLayout
        android:id="@+id/header_lokasi"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/header_rounded_bottom"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/btn_back_lokasi"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="56dp"
            android:src="@drawable/back"
            app:tint="@color/neutralwhite" />

        <TextView
            android:id="@+id/tv_title_lokasi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="54dp"
            android:layout_centerHorizontal="true"
            android:text="Cari Outlet"
            android:textColor="@color/neutralwhite"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/search_bar_outlet"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input"
            android:backgroundTint="#F5F5F5"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <EditText
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Cari Lokasi atau Kota...."
                android:inputType="text"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/location"
                app:tint="@color/neutraldark_grey" />
        </LinearLayout>
    </RelativeLayout>

    <!-- KONTEN UTAMA YANG BISA DI-SCROLL (PETA & CARD OUTLET) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_lokasi"
        android:layout_above="@id/bottom_navbar"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 2. GAMBAR PETA / MAPS (TEPAT DI BAWAH CARI OUTLET) -->
            <com.google.android.gms.maps.MapView
                android:id="@+id/mv_peta_outlet"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:contentDescription="Peta Lokasi Outlet Vin Coffee Cabang Mojokerto" />

            <!-- DAFTAR CARD OUTLET DENGAN PADDING SAMPING -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- 3. CARD OUTLET 1 (SAMA PLEK KETIPLEK GAMBAR {0774AFBC-B9C0-40FA-BE5E-F259875220F3}.png) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#D9D9D9"> <!-- Background abu-abu tipis figma -->

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <!-- Baris Judul & Status Buka -->
                        <LinearLayout
                            android:id="@+id/layout_title_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vin Coffee - Cabang Mojokerto"
                                android:textColor="@color/neutralblack"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="● Buka"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Deskripsi Alamat -->
                        <TextView
                            android:id="@+id/tv_alamat_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/layout_title_1"
                            android:layout_marginTop="6dp"
                            android:text="Jl. Semeru No. 24, Mojokerto"
                            android:textColor="@color/neutraldark_grey"
                            android:textSize="14sp" />

                        <!-- Teks Jarak Biru Tebal di Kiri Bawah -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tv_alamat_1"
                            android:layout_marginTop="12dp"
                            android:text="1.2 km dari lokasi Anda"
                            android:textColor="@color/primaryblue"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- Tombol Rute di Kanan Bawah -->
                        <Button
                            android:id="@+id/btn_rute_1"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:backgroundTint="@color/primaryblue"
                            android:text="Rute  ➔"
                            android:textAllCaps="false"
                            android:textColor="@color/neutralwhite"
                            android:textStyle="bold"
                            app:cornerRadius="8dp" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- 4. CARD OUTLET 2 (CABANG KEDUA UNTUK CADANGAN SCROLL) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#D9D9D9">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <LinearLayout
                            android:id="@+id/layout_title_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vin Coffee - Cabang Mojokerto"
                                android:textColor="@color/neutralblack"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_alamat_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/layout_title_2"
                            android:layout_marginTop="6dp"
                            android:text="Jl. Semeru No. 24, Mojokerto"
                            android:textColor="@color/neutraldark_grey"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tv_alamat_2"
                            android:layout_marginTop="12dp"
                            android:text="1.2 km dari lokasi Anda"
                            android:textColor="@color/primaryblue"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_rute_2"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:backgroundTint="@color/primaryblue"
                            android:text="Rute  ➔"
                            android:textAllCaps="false"
                            android:textColor="@color/neutralwhite"
                            android:textStyle="bold"
                            app:cornerRadius="8dp" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 5. BOTTOM NAVBAR -->
    <LinearLayout
        android:id="@+id/bottom_navbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#89CFF0"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/home"
            android:contentDescription="Home"
            app:tint="@color/primaryblue" />

        <ImageView
            android:id="@+id/nav_maps"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/location"
            android:contentDescription="Maps"
            app:tint="@color/primaryblue" />

        <ImageView
            android:id="@+id/nav_vouchers"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/promo"
            android:contentDescription="Vouchers"
            app:tint="@color/primaryblue" />

        <ImageView
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/profile"
            android:contentDescription="Profile"
            app:tint="@color/primaryblue" />
    </LinearLayout>

</RelativeLayout>